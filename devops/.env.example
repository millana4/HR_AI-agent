# Безопасность
AI_AGENT_API_KEY=str
SESSION_HASH_SALT=str

# Логирование
LOG_LEVEL=DEBUG
LOG_FILE=logs/agent.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3

# NocoDB
NOCODB_SERVER=https://server.com
NOCODB_API_TOKEN=str

AI_FAQ_TABLE_ID=str
AI_DOCUMENTS_TABLE_ID=str
